{
  "name": "webapp",
  "version": "0.9.24",
  "private": true,
  "type": "module",
  "config": {
    "releaseChannel": "beta"
  },
  "scripts": {
    "presets:manifest": "node scripts/generate-preset-manifest.mjs",
    "predev": "npm run presets:manifest",
    "dev": "next dev",
    "predev:beta": "npm run presets:manifest",
    "prebuild": "npm run presets:manifest",
    "dev:beta": "NEXT_PUBLIC_RELEASE_CHANNEL=beta next dev",
    "predev:prod": "npm run presets:manifest",
    "dev:prod": "NEXT_PUBLIC_RELEASE_CHANNEL=prod next dev",
    "build": "next build",
    "prebuild:beta": "npm run presets:manifest",
    "build:beta": "NEXT_PUBLIC_RELEASE_CHANNEL=beta next build",
    "prebuild:prod": "npm run presets:manifest",
    "build:prod": "NEXT_PUBLIC_RELEASE_CHANNEL=prod next build",
    "prestart": "npm run presets:manifest",
    "start": "next start",
    "prelint": "npm run presets:manifest",
    "lint": "next lint",
    "pretest:presets": "npm run presets:manifest",
    "test:presets": "node --test tests/preset-project-format.test.mjs",
    "test:roundtrip": "node --test tests/font-roundtrip.test.mjs",
    "test:grid": "node --test tests/grid-calculator.test.mjs",
    "test:reflow": "node --test tests/reflow-worker-contract.test.mjs",
    "test:autofit": "node --test tests/autofit-planner.test.mjs",
    "test:canvas-renderer": "node --test tests/canvas-page-renderer.test.mjs",
    "test:snapshot": "node --test tests/preview-layout-snapshot.test.mjs",
    "test:text": "node --test tests/text-layout.test.mjs",
    "test:optical": "node --test tests/optical-margin.test.mjs",
    "test:pdf": "node --test tests/pdf-export-rotation-contract.test.mjs",
    "test:svg": "node --test tests/svg-export-contract.test.mjs",
    "test:idml": "node --test tests/idml-export-contract.test.mjs",
    "test:perf": "node --test tests/perf-smoke.test.mjs",
    "test": "npm run test:presets && npm run test:roundtrip && npm run test:grid && npm run test:reflow && npm run test:autofit && npm run test:canvas-renderer && npm run test:snapshot && npm run test:text && npm run test:optical && npm run test:pdf && npm run test:svg && npm run test:idml && npm run test:perf",
    "fonts:sync": "../.venv-fonttools/bin/python scripts/sync_google_font_assets.py"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-slider": "^1.2.0",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fflate": "^0.8.2",
    "jspdf": "^4.1.0",
    "lucide-react": "^0.468.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
