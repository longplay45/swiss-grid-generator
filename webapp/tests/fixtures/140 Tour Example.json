    "steps": [
      {
        "id": "intro",
        "title": "Start on the Cover",
        "caption": "The tour can begin on a real project page. Use the page content as the teaching surface rather than a detached modal walkthrough.",
        "pageId": "page-quick-start-cover",
        "sidebarPanel": "layers"
      },
      {
        "id": "system-help",
        "title": "Jump to a Help Context",
        "caption": "A step can move to another page and open the relevant help section so the user sees both the specimen layout and the reference text.",
        "pageId": "page-quick-start-system",
        "helpSectionId": "help-baseline-grid"
      },
      {
        "id": "click-layer",
        "title": "Advance on a Real Click",
        "caption": "Click the paragraph about hover editing to continue. This demonstrates layer-click progression without hiding the page behind a separate wizard.",
