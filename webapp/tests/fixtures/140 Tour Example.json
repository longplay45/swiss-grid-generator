        "advanceOn": {
          "type": "layerClick",
          "layerKey": "workflow-b"
        }
      },
      {
        "id": "open-editor",
        "title": "Drive the Editor",
        "caption": "Tour steps can focus a layer and open the editor sidebar so onboarding stays tied to the actual production controls.",
        "pageId": "page-quick-start-workflow",
        "focusLayerKey": "workflow-c",
        "sidebarPanel": "layers",
        "autoSelectLayer": true,
        "openEditor": true
      },
      {
        "id": "save-load",
        "title": "End on Save and Load",
        "caption": "The same project JSON can carry both the document pages and the optional tour definition. This makes quick onboarding portable and editable.",
        "pageId": "page-quick-start-workflow",
        "helpSectionId": "help-save-load"
      }
    ]
